Personal Sanitario  = A FUNCTION OF( Hospitalizados basales,Hospitalizados criticos)
	~	
	~		|

Recuperados  = A FUNCTION OF( cuarentenables,Hospitalizados recuperados)
	~	
	~		|

vacunados  = A FUNCTION OF( Infecciosos)
