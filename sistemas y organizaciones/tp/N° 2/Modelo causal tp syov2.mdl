********************************************************
	.Control
********************************************************~
		Parámetros de control de simulación
	|

FINAL TIME  = 100
	~	Month
	~	El período final de la simulación.
	|

INITIAL TIME  = 0
	~	Month
	~	El período inicial de la simulación.
	|

SAVEPER  = 
        TIME STEP
	~	Month [0,?]
	~	La frecuencia con la que se almacena la salida.
	|

TIME STEP  = 1
	~	Month [0,?]
	~	El "Incremento de tiempo" para la simulación.
	|

